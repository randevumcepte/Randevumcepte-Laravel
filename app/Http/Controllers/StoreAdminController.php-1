                   $html .= '<td style="text-align:center"></td>';
                if($islemdetayi->biyik == true)
                   $html .= '<td style="text-align:center">X</td>';
                else
                   $html .= '<td style="text-align:center"></td>';
                if($islemdetayi->favori == true)
