   public function musteri_arama_bolumu_verileri(Request $request)
{
    $search = $request->input('query');
    $salonid = $request->input('sube');
    
    // Türkçe karakterleri İngilizce karşılıklarına çevir
    $normalizedSearch = str_replace(
        ['ı', 'ğ', 'ü', 'ş', 'ö', 'ç', 'İ', 'Ğ', 'Ü', 'Ş', 'Ö', 'Ç'],
        ['i', 'g', 'u', 's', 'o', 'c', 'I', 'G', 'U', 'S', 'O', 'C'],
        $search
    );

    $query = DB::table('musteri_portfoy')
        ->join('users', 'users.id', '=', 'musteri_portfoy.user_id')
        ->select(
            'users.id as id',
            DB::raw('CONCAT(users.name, " (", users.cep_telefon, ")") as ad_soyad'),
            'users.cep_telefon as cep_telefon',
            DB::raw('CONCAT("/isletmeyonetim/musteridetay/", users.id, "?sube=", musteri_portfoy.salon_id) as detayli_bilgi')
        )
        ->where(function($q) use ($search, $normalizedSearch) {
            $q->where('users.name', 'LIKE', "%{$search}%")
              ->orWhere('users.cep_telefon', 'LIKE', "%{$search}%")
              // Normalize edilmiş arama için ek koşul
              ->orWhere(DB::raw('REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(
                  REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(
                      LOWER(users.name),
                      "ı", "i"), "ğ", "g"), "ü", "u"), "ş", "s"), "ö", "o"), "ç", "c"),
                      "İ", "i"), "Ğ", "g"), "Ü", "u"), "Ş", "s"), "Ö", "o"), "Ç", "c")'), 
                  'LIKE', '%' . strtolower($normalizedSearch) . '%');
        })
        ->where('musteri_portfoy.salon_id', $salonid)->where('aktif',1)
  
        ->get();

    return response()->json($query);
}
    public function personel_secimi(Request $request)
    {
        $search = $request->input('query');
        $salonid = $request->input('sube');
        $query = DB::table('salon_personelleri')->select('id as id','personel_adi as ad_soyad')->where('personel_adi', 'LIKE', "%{$search}%")->where('salon_id', $salonid)->where('aktif',true)->limit(50)->get();
        return response()->json($query);
    }
    public function hizmet_secimi(Request $request)
    {
        $search = $request->input('query');
        $salonid = $request->input('sube');
        $query = DB::table('salon_sunulan_hizmetler')->join('hizmetler','salon_sunulan_hizmetler.hizmet_id','=','hizmetler.id')->select('hizmetler.id as id','hizmetler.hizmet_adi as hizmet_adi','salon_sunulan_hizmetler.sure_dk as sure','salon_sunulan_hizmetler.baslangic_fiyat as fiyat')->where('hizmetler.hizmet_adi', 'LIKE', "%{$search}%")->where('salon_sunulan_hizmetler.salon_id', $salonid)->where('salon_sunulan_hizmetler.aktif',true)->limit(100)->get();
        return response()->json($query);
    }
    public function hizmet_secimi_2(Request $request)
    { 
       return DB::table('salon_sunulan_hizmetler')->join('hizmetler','salon_sunulan_hizmetler.hizmet_id','=','hizmetler.id')->select(DB::raw('CONCAT("hizmet-" ,hizmetler.id) as id'),'hizmetler.hizmet_adi as text')->where('salon_sunulan_hizmetler.salon_id', $request->salonId)->where('salon_sunulan_hizmetler.aktif',true)->get(); 
    }
    public function urun_secimi(Request $request)
    {
        
         return DB::table('urunler')->select(DB::raw('CONCAT("urun-" ,id) as id'),'urun_adi as text')->where('aktif',1)->where('salon_id',$request->salonId)->get();

    }
    public function paket_secimi(Request $request)
    {
        return Paketler::select('id as id','paket_adi as text')->where('aktif',1)->where('salon_id',$request->salonId)->get();
    }
    public function cihaz_secimi(Request $request)
    {
        $search = $request->input('query');
        $salonid = $request->input('sube');
        $query = DB::table('cihazlar')->select('id as id','cihaz_adi as cihaz_adi')->where('cihaz_adi', 'LIKE', "%{$search}%")->where('salon_id', $salonid)->limit(50)->get();
        return response()->json($query);
    }
    public function oda_secimi(Request $request)
    {
        $search = $request->input('query');
        $salonid = $request->input('sube');
        $query = DB::table('odalar')->select('id as id','oda_adi as oda_adi')->where('oda_adi', 'LIKE', "%{$search}%")->where('salon_id', $salonid)->where('aktifmi',1)->limit(50)->get();
        return response()->json($query);
    }
    public function musteridanisanarama(Request $request)
    {
        $isletme = Salonlar::where('id',self::mevcutsube($request))->first();
        $html = '<option  value="0">';
        if($isletme->salon_turu_id==15 || $isletme->salon_turu_id==28||$isletme->salon_turu_id==29)
            $html .= 'Danışan ';
        else
            $html .= 'Müşteri ';
        $html .= 'Arayın...</option>';
        foreach(MusteriPortfoy::where('salon_id',$isletme->id)->where('aktif',true)->get() as $mevcutmusteri){
            $html .= '<option value="/isletmeyonetim/musteridetay/'.$mevcutmusteri->user_id;
            if(isset($_GET['sube']))
                $html .= '?sube='.$isletme->id;
            $html .= '">'.$mevcutmusteri->users->name;
            if($mevcutmusteri->users->cep_telefon != '' && $mevcutmusteri->users->cep_telefon !== null)
                $html .= '('.$mevcutmusteri->users->cep_telefon.')';
            $html .='</option>';
        }
        return $html;
    }
    public function acikadisyonlar(Request $request){
        $acik_adisyonlar = DB::table('randevu_hizmetler')->join('randevular','randevu_hizmetler.randevu_id','=','randevular.id')->join('hizmetler','randevu_hizmetler.hizmet_id','=','hizmetler.id')->join('users','randevular.user_id','=','users.id')->leftJoin('urun_satislari','urun_satislari.randevu_id','=','randevular.id')->join('salon_personelleri','randevu_hizmetler.personel_id','=','salon_personelleri.id')->leftJoin('urunler','urun_satislari.urun_id','=','urunler.id')->select(
                    'users.name as musteri',
                    DB::raw("CONCAT(GROUP_CONCAT(hizmetler.hizmet_adi),' (', GROUP_CONCAT(salon_personelleri.personel_adi), ')') as hizmetler"),
                    DB::raw('GROUP_CONCAT(urunler.urun_adi) as urunler'),
                    DB::raw('SUM(randevu_hizmetler.fiyat) + COALESCE(SUM(urun_satislari.fiyat), 0) as toplam'),
                    'randevular.tarih as tarih',
                    DB::raw('CONCAT("<a title=\"Detaylı Bilgi\" href=\"/isletmeyonetim/musteridetay/",randevular.id," type=\"button\" class=\"btn btn-info\"><i class=\"dw dw-eye\"></i></a>") as islemler'),
                )->where('randevular.salon_id',self::mevcutsube($request))->where('randevular.acik',true)->whereMonth('randevular.tarih','=',date('m'))->groupBy('randevu_hizmetler.randevu_id')->orderBy('randevular.id','desc')->get();
        return $acik_adisyonlar;
    }
    public function randevular(Request $request){
       
         $isletmeler = '';
        $isletme='';
        if(Auth::guard('satisortakligi')->check())
        {
            $isletmeler = [15];
            $isletme = Salonlar::where('id',15)->first();
        }
        else{
            $isletmeler = Auth::guard('isletmeyonetim')->user()->yetkili_olunan_isletmeler->where('aktif',1)->pluck('salon_id')->toArray();
            $isletme= Salonlar::where('id',self::mevcutsube($request))->first();
        }
         
        
        if(!in_array(self::mevcutsube($request),$isletmeler ))
        {
            return view('isletmeadmin.yetkisizerisim');
            exit(0);
        }
        if(str_contains(self::lisans_sure_kontrol($request),'-'))
        {
            return view('isletmeadmin.lisanssurebitti',['isletme'=>$isletme]);
            exit(0);
        }
        
       
        if(count($isletmeler)>1 && !isset($_GET['sube']))
        {
            return view('isletmeadmin.isletmesec',['isletmeler'=>$isletmeler,'isletme'=>$isletme]);
            exit(0);
        }
        $randevular = '';
        if(self::personelmi($request))
            $randevular = self::randevuyukle($request,1,date('Y-m-d'),date('Y-m-d'));
        else
            $randevular = self::randevuyukle($request,Salonlar::where('id',self::mevcutsube($request))->value('randevu_takvim_turu'),date('Y-m-d'),date('Y-m-d'));
        $kalan_uyelik_suresi =
             self::lisans_sure_kontrol($request);
        
        return view('isletmeadmin.randevular',['bildirimler'=>self::bildirimgetir($request),  'sayfa_baslik'=>'Randevu Takvimi','pageindex' => 2,'randevular'=>$randevular,'isletme'=>$isletme,'kalan_uyelik_suresi'=>$kalan_uyelik_suresi,'yetkiliolunanisletmeler'=>$isletmeler]);
    }
