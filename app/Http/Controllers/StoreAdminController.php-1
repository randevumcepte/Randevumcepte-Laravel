    {
        $hizmet = AdisyonHizmetler::where('id',$request->hizmet_id)->first();
        $hizmet->hizmet_id = $request->adisyon_hizmet_id;
        $hizmet->save();
        return self::adisyon_hizmet_getir($hizmet->id);
    }
    public function adisyonhizmetfiyatguncelle(Request $request)
    {
        $hizmet = AdisyonHizmetler::where('id',$request->hizmet_id)->first();
        $hizmet->fiyat = $request->tutar;
        $hizmet->save();
        $adisyon = Adisyonlar::where('id',$hizmet->adisyon_id)->first();
        return array(
            'hizmet_liste'=>self::adisyon_hizmet_getir($hizmet->id),
            'adisyon_detay'=>self::adisyon_detay($request,$adisyon,false,''),
        );
    }
    public function hizmetdogrulamakodugonder(Request $request)
    {
        $hizmet = AdisyonHizmetler::where('id',$request->hizmet_id)->first();
        $random = str_shuffle('1234567890');
        $kod = substr($random, 0, 4);
        $hizmet->dogrulama_kodu = $kod;
        $hizmet->save();
        $musteri = User::where('id',Adisyonlar::where('id',$hizmet->adisyon_id)->value('user_id'))->first();
        $mesaj = array(
            array("to"=>$musteri->cep_telefon,"message"=>"Doğrulama kodunuz : ".$kod),
        );
          self::sms_gonder_bildirimli($request,$mesaj,false,1,true);
        return '';
    }
    public function seans_dogrulama_kodu_gonder(Request $request)
    {
        $seans = AdisyonPaketSeanslar::where('id',$request->seans_id)->first();
        $adisyon_paket = AdisyonPaketler::where('id',$seans->adisyon_paket_id)->first();
        $random = str_shuffle('1234567890');
        $kod = substr($random, 0, 4);
        $seans->dogrulama_kodu = $kod;
        $seans->save();
        if(Randevular::where('seans_id',$seans->id)->count()==1)
        {
            $randevu = Randevular::where('seans_id',$seans->id)->first();
            $randevu->dogrulama = $kod;
            $randevu->save();
        }
        $mesaj = array(
            array("to"=>$adisyon_paket->adisyon->musteri->cep_telefon,"message"=>"Doğrulama kodunuz : ".$kod),
        );
         self::sms_gonder_bildirimli($request,$mesaj,false,1,true);
        return '';
    }
  public function randevugeldiisaretle(Request $request)
{
    $randevu = Randevular::where('id', $request->randevuid)->first();
    $kvkkOnayiAktif = SalonSMSAyarlari::where('salon_id', $request->sube)
        ->where('ayar_id', 22)
        ->value('musteri');
    
    $portfoy = MusteriPortfoy::where('user_id', $randevu->user_id)
        ->where('salon_id', $randevu->salon_id)
        ->first();

    $olusturulanOnayKodu = $portfoy->onay_kodu;
    
    // KVKK kontrolü - sadece ilk defa geliyorsa
    if ($kvkkOnayiAktif && !$portfoy->kvkk_onay_alindi) {
        // Eğer doğrulama kodu henüz girilmemişse
        if (!$request->isKvkkProcess && $request->dogrulama_kodu == '' && $request->kvkkOnayKodu == '') {
            // Önce doğrulama kodunu iste
            $dogrulama_kodu_ayari = SalonSMSAyarlari::where('salon_id', $randevu->salon_id)
                ->where('ayar_id', 16)
                ->value('musteri');
            
            if ($dogrulama_kodu_ayari) {
                return array(
                    'dogrulamaGerekli' => 1,
                    'hatamesaj' => 'Lütfen önce doğrulama kodunu giriniz'
                );
            }
        }
        
        // KVKK kodu kontrolü
        if ($request->isKvkkProcess && $request->kvkkOnayKodu == '') {
            // KVKK kodu gönder
            $onayMesaji = "Sn. ".$randevu->users->name.", ".$olusturulanOnayKodu." numarali onay kodunu ilgiliye soyleyerek, ".$randevu->salonlar->kvkk_link." kvkk linkinde yer alan KVKK Aydinlatma Metni'ne gore kisisel verilerinizin islenmesine ve sistemlerimizde kayitli iletisim adresleriniz uzerinden SMS, e-posta ve aramalar vasitasiyla ticari elektronik ileti gonderimine izin vermis olacaksiniz";
            
            Log::info('KVKK SMS gönderilecek');
            self::sms_gonder_bildirimli($request, array(array(
                "to" => $randevu->users->cep_telefon,
                "message" => $onayMesaji
            )), false, 1, false);
            
            return array(
                'detailtext' => '',
                'title' => 'Uyarı',
                'mesaj' => '<p>Müşteri bilgilerini sisteme kaydetmeden önce verilerinin işlenmesine ve kayıtlı iletişim adresleri üzerinden SMS, e-posta ve aramalar vasıtasıyla ticari elektronik ileti gönderimine izin verdiğine dair cep telefonuna gönderilen onay kodunu girmeniz gerekmektedir.<p>',
                'onayGerekli' => true,
                'status' => 'warning',
                'showCloseButton' => false,
                'showCancelButton' => true,
                'showConfirmButton' => true,
            );
        } 
        elseif ($request->isKvkkProcess && $request->kvkkOnayKodu != '' && $request->kvkkOnayKodu != $olusturulanOnayKodu) {
            Log::info('KVKK yanlış girildi tekrar uyarı');
            return array(
                'detailtext' => '',
                'title' => 'Uyarı',
                'mesaj' => '<p>Girilen onay kodu hatalı. Lütfen müşteriye gönderilen doğru onay kodunu giriniz.<p>',
                'onayGerekli' => true,
                'status' => 'warning',
                'showCloseButton' => false,
                'showCancelButton' => true,
                'showConfirmButton' => true,
            );
        }
        
        // KVKK kodu doğru girildiyse kaydet
        if ($request->kvkkOnayKodu == $olusturulanOnayKodu) {
            $portfoy->kvkk_onay_alindi = true;
            $portfoy->save();
        }
    }

    // Doğrulama kodu kontrolü
    $dogrulama_kodu_ayari = SalonSMSAyarlari::where('salon_id', $randevu->salon_id)
        ->where('ayar_id', 16)
        ->value('musteri');
    
    // Doğrulama gerekiyor mu?
    if ($dogrulama_kodu_ayari) {
        // Eğer KVKK işlemindeysek ve doğrulama kodu daha önce girilmediyse
        if ($request->isKvkkProcess && $request->dogrulama_kodu == '') {
            // Doğrulama kodu iste
            return array(
                'dogrulamaGerekli' => 1,
                'hatamesaj' => 'Lütfen doğrulama kodunu giriniz'
            );
        }
        
        // Doğrulama kodu kontrolü
        if ($randevu->dogrulama != $request->dogrulama_kodu) {
            return array(
                'dogrulamaGerekli' => 1,
                'hatamesaj' => 'Doğrulama kodu hatalı, lütfen yeniden deneyiniz'
            );
        }
    }

    // Tüm kontroller başarılı, randevuyu işaretle


        /*$request->merge([
            'sube' => $randevu->salon_id,
            'userId' => $randevu->user_id,
            'paketRandevuOnayiVar' => false,
         
        ]);
 

        
    

        
        $hizmetSeansVarmi = Adisyonlar::whereHas('hizmetler',function($q) use($randevu){
            $hizmetler = $randevu->hizmetler->pluck('hizmet_id')->toArray();
            $q->whereIn('hizmet_id',$hizmetler)->where('otomatik_randevu_olusturuldu','!=',1)->where('bekleyen_seans','>',0);
        })->where('user_id',$randevu->user_id)->where('salon_id',$randevu->salon_id)->first();

         
        
        
        $paketSeansVarmi = Adisyonlar::whereHas('paketler',function($q) use($randevu){
                $q->whereHas('paket',function($q2) use($randevu){
                                $q2->whereHas('hizmetler',function($q3) use($randevu){
                                    $q3->whereIn('hizmet_id',$randevu->hizmetler->pluck('hizmet_id')->toArray());
                                });
                })->where('otomatik_randevu_olusturuldu','!=',1)->where('bekleyen_seans','>',0);
                            
        })->where('user_id',$randevu->user_id)->where('salon_id',$randevu->salon_id)->first();


        if($hizmetSeansVarmi || $paketSeansVarmi)
        {
             
            if(!filter_var($request->input('seansDusmeYapildi'), FILTER_VALIDATE_BOOLEAN))
            {
                
                
                return array(
                        'seansDusumuBildir'=>true,
                        'seanslar'=> view('partials.seansEkrani',['hizmetSeansVarmi'=>$hizmetSeansVarmi,'paketSeansVarmi'=>$paketSeansVarmi,'randevu'=>$randevu])->render(),
                         
                );
                exit;
            }

        }*/
         
        
        $randevu->randevuya_geldi = true;
     
        $randevu->save();
        $seanslar = AdisyonPaketSeanslar::where('randevu_id',$randevu->id);
        foreach($randevu->hizmetler as $randevuHizmet)
        {
           // if(in_array($randevuHizmet->hizmet_id, $seanslar->pluck('hizmet_id')->toArray())){
                $randevuHizmet->seansa_geldi = true;
                $randevuHizmet->save(); 
            //}
                
        }
        foreach($seanslar->get() as $seans)
        {

            $seans->geldi = true;
            $seans->save();
        }
             

    // Bildirim gönderimi
    $mesajlar = array();
    foreach ($randevu->hizmetler as $hizmet) {
        $mesaj = $randevu->users->name . " isimli müşteriniz " . date('H:i', strtotime($hizmet->saat)) . " " . $hizmet->hizmetler->hizmet_adi . " randevusu için işletmenize gelmiştir.";
        if (SalonSMSAyarlari::where('salon_id', $randevu->salon_id)
            ->where('ayar_id', 21)
            ->value('personel') == 1) {
            
            Log::info('Geldi bildirimi personele gidecek');
            
            
            $yetkiliid = Personeller::where('id', $hizmet->personel_id)->value('yetkili_id');
            array_push($mesajlar, array(
                "to" => IsletmeYetkilileri::where('id', $yetkiliid)->value('gsm1'),
                "message" => $mesaj
            ));
        }

        self::bildirimekle($request, $randevu->salon_id, $mesaj, "#", $hizmet->personel_id, null, Auth::guard('isletmeyonetim')->user()->profil_resim, $randevu->id);
        
        $bildirimkimlikleri = BildirimKimlikleri::where('isletme_yetkili_id', $hizmet->personel_id)
            ->pluck('bildirim_id')
            ->toArray();
        
        self::bildirimgonder($bildirimkimlikleri, "Yeni Randevu", $mesaj, $randevu->salon_id, '12d6537e-7a7d-4d1d-a838-e3fc947eaf44', '5e50f84e-2cd8-4532-a765-f2cb82a22ff9', 'os_v2_app_lzipqtrm3bctfj3f6lfyfirp7ghx6w4i7t6e6iufqzlj6ginpkucdwamtgxy5bclne737yh7y62zxlfmep2c4ijioiimrps4jcq5ysi');
    }
    
    if (count($mesajlar) > 0) {
        Log::info('Geldi bildirimi personele gönder');
        self::sms_gonder_bildirimli($request, $mesajlar, false, 1, false);
    }
    
    return array('mesaj' => 'Başarılı', 'geldiIsaretlendi' => true);
}
