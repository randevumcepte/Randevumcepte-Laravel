    public function personelmi(Request $request)
    {
       
        $userSatis = Auth::guard('satisortakligi')->user();
        $userIsletme = Auth::guard('isletmeyonetim')->user();

        return DB::table('model_has_roles')
        ->where('role_id', 5)
        ->where(function($q) use ($userSatis, $userIsletme, $request) {
            // SatisOrtakligi guard'ından gelen kullanıcı varsa
            if ($userSatis) {
                $q->where('model_id', $userSatis->id);
            }

            // IsletmeYonetim guard'ından gelen kullanıcı varsa
            if ($userIsletme) {
                $q->orWhere('model_id', $userIsletme->id);
            }
        })
        ->where('salon_id', self::mevcutsube($request))
        ->count() > 0;
    }
    public function musteridanisantext($salon_id)
    {
        if(Salonlar::where('id',$salon_id)->value('salon_turu_id') == 15 ||Salonlar::where('id',$salon_id)->value('salon_turu_id') == 28|| Salonlar::where('id',$salon_id)->value('salon_turu_id') == 29)
        {
            return array(
                'kelime'=>'danışan',
                'ek'=>'ın'
            );
            exit;
        }
        else
        {
            return array(
                'kelime'=>'müşteri',
                'ek'=>'nin'
            );
            exit;
        }
    }
    public function easistandata(Request $request,$bugunYarin)
    {

        $isletmeId = self::mevcutsube($request);
        $randevular = Randevular::has('hizmetler')->where('durum',1)->where(function($q){
                $q->where('randevuya_geldi',null);
            $q->orWhere('randevuya_geldi','!=',0);
        })->where('salon_id',$isletmeId)->where(function($q) use($bugunYarin){
                $q->where('tarih', date('Y-m-d', strtotime('+'.($bugunYarin+1) .' days', strtotime(date('Y-m-d')))));
                $q->orWhere('onceki_tarih', date('Y-m-d', strtotime('+'.($bugunYarin+1).' days', strtotime(date('Y-m-d')))));
        })->get();
        $alacaklar = Alacaklar::where('salon_id',$isletmeId)->where(function ($q) use($bugunYarin) {
                $q->where('planlanan_odeme_tarihi', date('Y-m-d', strtotime('+'.($bugunYarin+2).' days', strtotime(date('Y-m-d')))));
                $q->orWhere('onceki_planlanan_odeme_tarihi', date('Y-m-d', strtotime('+'.($bugunYarin+2).' days', strtotime(date('Y-m-d')))));
        })->get();
        $kampanyalar = KampanyaYonetimi::where('salon_id',$isletmeId)->where(function($q) use($bugunYarin){
                $q->where('asistan_tarih_saat', 'LIKE','%'.date('Y-m-d', strtotime('+'.($bugunYarin).' days', strtotime(date('Y-m-d')))).'%');
                $q->orWhere('asistan_tarih_saat','LIKE', '%'.date('Y-m-d', strtotime('+'.($bugunYarin).' days', strtotime(date('Y-m-d')))).'%');
        })->get();


        $formattedRandevular = $randevular->map(function($randevu){
            $baslik = $randevu->users->name." isimli ";
            $sonuc = "";
            $islemler = "";
            $durum = "";
              $saat = "";
            if($randevu->salonlar->salon_turu_id == 15||$randevu->salonlar->salon_turu_id == 28||$randevu->salonlar->salon_turu_id == 29 )
                $baslik .=" danışanın ";
            else
                $baslik .=" müşterinin ";
            $baslik .= date('d.m.Y', strtotime($randevu->tarih))." randevu hatırlatmasını ";
            if($randevu->hatirlatma_aramasi_yapildi)
                $baslik .= " yaptım.";
            else
                $baslik .= " yapacağım."; 
            if($randevu->hatirlatma_aramasi_yapildi == 1 && $randevu->randevuya_gelecek == 1)
                $sonuc = "Randevuya gelecek.";
            elseif($randevu->hatirlatma_aramasi_yapildi == null)
                $sonuc = "Hatırlatma araması yapılacak.";
            elseif($randevu->hatirlatma_ulasilamadi == 1 && $randevu->tekrar_arandi != 1)
                $sonuc = "Ulaşılamadı. ".date('H:i',strtotime($randevu->tekrar_arama_tarih_saat))." de tekrar arayacağım.";
            elseif($randevu->asistan_guncelledi == 1)
                $sonuc = "Asistan tarafından ".date('d.m.Y',strtotime($randevu->tarih))." ".date('H:i',strtotime($randevu->saat))." olarak güncellendi.";
            else
                $sonuc = date('H:i',strtotime($randevu->tekrar_arama_tarih_saat))." saatinde tekrar aradım, ulaşılamadı";
            if(
                ($randevu->hatirlatma_gorevi_iptal != 1 || $randevu->hatirlatma_gorevi_iptal == null) &&
                (
                    ($randevu->hatirlatma_aramasi_yapildi == 1 && $randevu->hatirlatma_ulasilamadi == 1) ||
                    ($randevu->hatirlatma_aramasi_yapildi == null || $randevu->hatirlatma_aramasi_yapildi != 1)

                )&&($randevu->tekrar_arandi != 1 || $randevu->tekrar_arandi == null)

            )
                $islemler = '<button name="gorev_iptal_et_randevu" class="btn btn-primary btn-block" data-value="'. $randevu->id.'" style="line-height:5px;width:auto">Görevi İptal Et</button>';
            if($randevu->hatirlatma_ulasilamadi == 1)
                $durum = '<button class="btn btn-danger btn-block" style="line-height:5px;width:auto">Ulaşılamadı</button>';
           

            if($randevu->hatirlatma_aramasi_yapildi === null)
                $saat = date('H:i',strtotime($randevu->saat));
            else
                $saat = date('H:i',strtotime($randevu->arama_saat));
             


            return [
                'baslik'=>"Randevu Hatırlatması",
                'mesaj'=>$baslik,
                'sonuc'=>$sonuc,
                'islemler'=>$islemler,
                'durum'=>$durum,
                'saat'=>$saat,
                'randevu_id'=>$randevu->id,
            ];
        });
        $formattedAlacaklar = $alacaklar->map(function($alacak){
            $baslik = $alacak->musteri->name." isimli ";
            $sonuc = "";
            $islemler = "";
            $durum = "";
            if($alacak->salon->salon_turu_id == 15||$alacak->salon->salon_turu_id == 28||$alacak->salon->salon_turu_id == 29 )
                $baslik .=" danışanın ";
            else
                $baslik .=" müşterinin ";
            $baslik .= date('d.m.Y', strtotime($alacak->planlanan_odeme_tarihi))." tarihindeki ".number_format($alacak->tutar,2,',','.')." ₺ tutarındaki ";
            if($alacak->taksitli_tahsilat_id !== null)
                $baslik .= "taksidinin ";
            else
                $baslik .= "senedinin ";
            $baslik.=" ödeme hatırlatmasını";
            if($alacak->hatirlatma_aramasi_yapildi)
                $baslik .= " yaptım.";
            else
                $baslik .= " yapacağım."; 
            if($alacak->hatirlatma_aramasi_yapildi == 1 && $alacak->odenecek == null && $alacak->hatirlatma_ulasilamadi == 0)
                $sonuc = "Hatırlatma araması yapıldı.";
            elseif($alacak->hatirlatma_aramasi_yapildi == null)
                $sonuc = "Hatırlatma araması yapılacak.";
            elseif($alacak->odenecek == 1)
                $sonuc = "Zamanında ödenecek.";
            elseif($alacak->asistan_guncelledi == 1)
                $sonuc = "Asistan tarafından ".date('d.m.Y',strtotime($alacak->planlanan_alacak_tarihi))." olarak güncellendi.";
            elseif($alacak->tekrar_arandi != 1 && $alacak->tekrar_arandi !== null)
                $sonuc = "Ulaşılamadı. ".date('H:i',strtotime($alacak->tekrar_arama_tarih_saat))." saatinde tekrar arayacağım";
            else
                $sonuc = date('H:i',strtotime($alacak->tekrar_arama_tarih_saat))." saatinde tekrar aradım, ulaşılamadı";
            if($alacak->hatirlatma_ulasilamadi == 1 )
                $durum = '<button class="btn btn-success btn-block" style="line-height:5px;width:auto">Ulaşıldı</button>';

             

            if(
                ($alacak->hatirlatma_gorevi_iptal != 1 || $alacak->hatirlatma_gorevi_iptal == null) &&
                (
                    ($alacak->hatirlatma_aramasi_yapildi == 1 && $alacak->hatirlatma_ulasilamadi == 1) ||
                    ($alacak->hatirlatma_aramasi_yapildi == null || $alacak->hatirlatma_aramasi_yapildi != 1)

                )&&($alacak->tekrar_arandi != 1 || $alacak->tekrar_arandi == null)

            )
                $islemler = '<button name="gorev_iptal_et_alacak" class="btn btn-primary btn-block" data-value="'. $alacak->id.'" style="line-height:5px;width:auto">Görevi İptal Et</button>';


            return [
                'baslik'=>'Alacak Hatırlatması',
                'mesaj'=>$baslik,
                'sonuc'=>$sonuc,
                'islemler'=>$islemler,
                'durum'=>$durum,
                'saat'=>date('H:i',strtotime($alacak->arama_saat)),
                'alacak_id'=>$alacak->id,
            ];

        });
        $formattedKampanyalar = $kampanyalar->map(function($kampanya){
            $baslik = $kampanya->paket_isim." kampanya ";
            $sonuc = "";
            $durum = '<a style="color:#fff;width:auto;line-height:5px" class="btn btn-primary" data-value="'.$kampanya->id.'" data-toggle="modal" name="kampanya_detay" data-target="#kampanya_detay_modal">Rapor Detayı >></a>';
            $islemler = "";
              
            if($kampanya->arama_ile_gonderim == 1 && $kampanya->sms_ile_gonderm != 1)
                $baslik = "arama ";
            elseif($kampanya->arama_ile_gonderim != 1 && $kampanya->sms_ile_gonderm == 1)
                $baslik = "SMS ";
            else
                $baslik = "arama ve SMS ";
            $baslik = "ile tanıtımını";
            if($kampanya->arama_yapildi || $kampanya->sms_gonderildi)
                $baslik = "yaptım.";
            else
                $baslik = "yapacağım.";

            return [
                'baslik'=>'Kampanya Hatırlatması',
                'mesaj'=>$baslik,
                'sonuc'=>$sonuc,
                'islemler'=>$islemler,
                'durum'=>$durum,
                'saat'=>date('H:i',strtotime($kampanya->asistan_tarih_saat)),
                'kampanya_id'=>$kampanya->id,
            ];
        });
        $merged = collect()
    ->merge($formattedRandevular)
    ->merge($formattedAlacaklar)
    ->merge($formattedKampanyalar);
        return $merged;

     
           
               
    }
    public function gorev_iptal_et(Request $request)
    {
        $mesaj = self::gorevIptalEt($request);
        return array(
            "mesaj"=>$mesaj,
            "easistandata"=> self::easistandata($request,0),
            "easistanYarinYapilacak" =>self::easistandata($request,1),

        );
    }
    public function generateQRCode()
    {
        $userId = auth()->guard('satisortakligi')->id(); // Get the authenticated user ID
        $qrCodeData = route('whatsapp.auth', ['user_id' => $userId]); // URL for QR code scan
        
        $qrCode = new QrCode($qrCodeData); // Generate QR code with the login URL
        $qrCode->setSize(300);
        
        // Return the QR code as a data URI
        return response()->json([
            'qr_code' => $qrCode->writeDataUri() // This will give you a base64 encoded image
        ]);
    }
    
    // Authenticate user after scanning QR Code
    public function authenticateUser(Request $request, $userId)
    {
        if ($request->user_id == $userId) {
            // Successful authentication, set the session
            Session::put('whatsapp_authenticated', true);
            return response()->json(['status' => 'success', 'message' => 'User authenticated successfully']);
        }

        return response()->json(['status' => 'error', 'message' => 'Invalid user']);
    }

    // Check if user is authenticated
    public function checkAuthentication()
    {
        if (Session::has('whatsapp_authenticated')) {
            return response()->json(['status' => 'authenticated']);
        }

        return response()->json(['status' => 'not_authenticated']);
    }
