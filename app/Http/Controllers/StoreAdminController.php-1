                 $kaynak = $_FILES["musteriresimyukle"]["tmp_name"][$i];
                 $dosya  = str_replace(" ", "_", $_FILES["musteriresimyukle"]["name"][$i]);
                 $dosya  = str_replace(" ", "-", $_FILES["musteriresimyukle"]["name"][$i]);
                 $uzanti = explode(".", $_FILES["musteriresimyukle"]["name"][$i]);
                 $hedef  = "./" . $dosya;
