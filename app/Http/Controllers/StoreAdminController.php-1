    public function adisyonOdemeDetaylari(Request $request)
    {
        $adisyon = Adisyonlar::where('id',$request->adisyon_id)->first();
        $tahsilatIdler = array();
        foreach($adisyon->hizmetler as $hizmet)
        {
            foreach($hizmet->tahsilatlar as $hizmetTahsilat)
                array_push($tahsilatIdler,$hizmetTahsilat->tahsilat_id);

        }
        foreach($adisyon->urunler as $urun)
        {
            foreach($urun->tahsilatlar as $urunTahsilat)
                array_push($tahsilatIdler,$urunTahsilat->tahsilat_id);

        }
        foreach($adisyon->paketler as $paket)
        {
            foreach($paket->tahsilatlar as $paketTahsilat)
                array_push($tahsilatIdler,$paketTahsilat->tahsilat_id);

        }
        $html = "<table class='table'><thead><tr><td style='text-align:center'>Ödeme Tarihi</td><td style='text-align:center'>Tutar (₺)</td><td style='text-align:center'>Ödeme Yöntemi</td></tr></thead></tbody>";
        $tahsilatlar = Tahsilatlar::whereIn('id',$tahsilatIdler)->orderBy('odeme_tarihi','asc')->get();
        foreach($tahsilatlar as $tahsilat){
             $html .= "<tr><td style='text-align:center'>".date('d.m.Y',strtotime($tahsilat->odeme_tarihi))."</td>
            <td style='text-align:center'>".number_format($tahsilat->tutar,2,',','.')."</td>
            <td style='text-align:center'>".$tahsilat->odeme_yontemi->odeme_yontemi."</td>";
        }
           
        
        $html .= "</tbody></table>";
        return $html;

    }
    public function paketTahsilatlari(Request $request)
    {
        $seansBilgi = AdisyonPaketSeanslar::where('hizmet_id',$request->hizmetId)->where('randevu_id',$request->randevuId)->first();
        $paketHizmetId = "";
        $seansli = false;
        $paketVar = false;
        $adisyonBilgi = '';
        $tahsilatUrl = '';
        if(!$seansBilgi){
            $adisyonHizmetBilgi =  AdisyonHizmetler::where('randevu_id',$request->randevuId)->first();
            $adisyonBilgi = Adisyonlar::where('id',$adisyonHizmetBilgi->adisyon_id)->first();
            $paketHizmetId = $adisyonHizmetBilgi->id;
        }
        else   {
            $paketVar = true;
            $paketHizmetId = $seansBilgi->adisyon_paket_id ? $seansBilgi->adisyon_paket_id : $seansBilgi->adisyon_hizmet_id;
        }
         
        $tahsilatIdler = array();
        $tahsilatBilgileri = '';
        if($seansBilgi){
             if($seansBilgi->adisyon_paket_id){
                    $tahsilatBilgileri = TahsilatPaketler::where('adisyon_paket_id',$paketHizmetId)->get();
            }
            else{
                $tahsilatBilgileri = TahsilatHizmetler::where('adisyon_hizmet_id',$paketHizmetId)->get();
             
            }
           
        }
        else{

            $tahsilatBilgileri = TahsilatHizmetler::where('adisyon_hizmet_id',$paketHizmetId)->get();

        }
        $tahsilatTutari = 0;
       

        $html = "<table class='table'><thead><tr><td style='text-align:center'>Ödeme Tarihi</td><td style='text-align:center'>Tutar (₺)</td><td style='text-align:center'>Ödeme Yöntemi</td></tr></thead></tbody>";
        foreach($tahsilatBilgileri as $tahsilatBilgi)
        { 

            $tahsilatlar = Tahsilatlar::where('id',$tahsilatBilgi->tahsilat_id)->orderBy('odeme_tarihi','asc')->get();

            foreach($tahsilatlar as $tahsilat)
            {
                        $html .= "<tr><td style='text-align:center'>".date('d.m.Y',strtotime($tahsilat->odeme_tarihi))."</td>
                        <td style='text-align:center'>".number_format($tahsilatBilgi->tutar,2,',','.')."</td>
                        <td style='text-align:center'>".$tahsilat->odeme_yontemi->odeme_yontemi."</td>";
            }
            $html .= "</tbody></table>";
        }
        
        
        return  array('odemeler'=>$html);
       

    }
    public function personelSiralamaAzalt(Request $request)
    {     
        $personel2 = Personeller::where('takvim_sirasi',$request->siraNo-1)->where('salon_id',$request->sube)->first();
        $personel2->takvim_sirasi = $personel2->takvim_sirasi + 1;
        $personel2->save();
        $personel = Personeller::where('id',$request->personelid)->first();
        $personel->takvim_sirasi = $request->siraNo-1;
        $personel->save();
       
        return self::personel_liste_getir($request);
    }
