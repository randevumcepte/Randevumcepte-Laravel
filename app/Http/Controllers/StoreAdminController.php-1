    function birlestirAyniBaslik($data) {
        $sonuc = [];

        foreach ($data as $item) {
            $baslik = $item['baslik'];
            $seans = (int) $item['seans'];
            $fiyat = (float) $item['fiyat'];

            if (isset($sonuc[$baslik])) {
                // Aynı başlık varsa, seans sayısını ekleyelim
                $sonuc[$baslik]['seans'] += $seans;
                $sonuc[$baslik]['fiyat'] += $fiyat;
            } else {
                // Yeni başlık için kaydı ekleyelim
                $sonuc[$baslik] = [
                    'baslik' => $baslik,
                    'seans' => $seans,
                    'fiyat' => number_format($fiyat, 2, '.', '')
                ];
            }
        }

        // Sonucu sıfırdan dizinin içine aktarıyoruz
        return array_values($sonuc);
    }

     public function seansAyristirma($text)
    {
       

        // 1. Metni virgüllere göre parçala
        $protokoller = explode(',', $text);

        $sonuc = [];

        foreach ($protokoller as $protokol) {
            // 2. Parantez içindeki değeri almak için regex kullan
            preg_match('/\((\d+ Seans) = ([0-9]+\.[0-9]{2} TRY)\)/', $protokol, $matches);
            
            if (!empty($matches)) {
                $seans = $matches[1]; // "18 Seans"
                $fiyat = $matches[2]; // "7000.00 TRY"

                // 3. Parantez öncesindeki kısmı almak için ayır
                $baslik = trim(str_replace($matches[0], '', $protokol)); // "6 X 12 PROTOKOLÜ"

                // 4. Sonucu diziye ekle
                $sonuc[] = [
                    'baslik' => $baslik,
                    'seans' => str_replace(" Seans","",$seans),
                    'fiyat' => str_replace(" TRY","",$fiyat),
                ];
            }
        }

        
        return($sonuc);
    }
public function adisyon_filtreli_getir(Request $request)
{
    $tur = $request->tur ?? 0; // 0: tümü, 1: hizmet, 2: paket, 3: ürün
    $durum = '';
    $personelid = $request->personel_id ?? '';
    $musteriid = $request->musteri_id ?? '';
    
    // Varsayılan tarih aralığı (bu ay)
    $tarih1 = date('Y-m-01') . ' 00:00:00';
    $tarih2 = date('Y-m-t') . ' 23:59:59';
    if($musteriid != '')
    {
            $tarih1 = '1970-01-01 00:00:00';
            $tarih2 = date('Y-m-t') . ' 23:59:59';
    }

    // Eğer tarih aralığı gönderilmişse onu kullan
    if (!empty($request->tariharaligi)) {
        $tarih = explode(' / ', $request->tariharaligi);
        if (count($tarih) === 2) {
            $tarih1 = trim($tarih[0]) . ' 00:00:00';
            $tarih2 = trim($tarih[1]) . ' 23:59:59';
        }
    }
    
    
    Log::info($tarih1.' - '.$tarih2.' satışları geliyor Müşteri : '. $musteriid.' Personel : '. $personelid.' Tür : '.$tur);
    return self::adisyon_yukle($request, $tur, null, $tarih1, $tarih2, $musteriid, $personelid);
}   

public function adisyon_filtreli_getir_personel(Request $request)
{
    $tur = $request->satisturu;
    $tarih1 = $request->yil.'-'.$request->ay.'-01 00:00:00';
    $tarih2 = $request->yil.'-'.$request->ay.'-31 23:59:59';
    $personelid = $request->personelid;
    
    // Durum parametresini ekleyin (eğer varsa)
    $durum = $request->durum ?? '';
    
    return self::adisyon_yukle_tahsilat($request, $tur, $durum, $tarih1, $tarih2, '', $personelid, '');
}
public function personel_listesi_getir(Request $request)
{
    $salon_id = $request->sube ?? self::mevcutsube($request);
    
    $personeller = DB::table('salon_personelleri')
        ->where('salon_id', $salon_id)
        ->where('aktif', 1)
        ->select('id', 'personel_adi')
        ->orderBy('personel_adi')
        ->get();
    
    return response()->json($personeller);
}
    public function seanstakip(Request $request){
        $isletmeler = '';
        $isletme='';
        if(Auth::guard('satisortakligi')->check())
        {
            $isletmeler = [15];
            $isletme = Salonlar::where('id',15)->first();
        }
        else{
            $isletmeler = Auth::guard('isletmeyonetim')->user()->yetkili_olunan_isletmeler->where('aktif',1)->pluck('salon_id')->toArray();
            $isletme= Salonlar::where('id',self::mevcutsube($request))->first();
        }
        
        
        if(!in_array(self::mevcutsube($request),$isletmeler ))
        {
            return view('isletmeadmin.yetkisizerisim');
            exit(0);
        }
        if(str_contains(self::lisans_sure_kontrol($request),'-'))
        {
            return view('isletmeadmin.lisanssurebitti',['isletme'=>$isletme]);
            exit(0);
        }
        if(!Auth::guard('satisortakligi')->check()){
             if(self::personelmi($request))
            {
                    return redirect()->route('isletmeadmin.randevular');
                    exit(0);
            }
        }
       
        if(count($isletmeler)>1 && !isset($_GET['sube']))
        {
            return view('isletmeadmin.isletmesec',['isletmeler'=>$isletmeler,'isletme'=>$isletme]);
            exit(0);
        }
       $isletme = Salonlar::where('id',self::mevcutsube($request))->first();

       $adisyonlar = '' /*self::seans_getir($request,0,'1970-01-01 00:00:00',date('Y-m-d 23:59:59'),'')*/;
       
       return view('isletmeadmin.seanstakip',['bildirimler'=>self::bildirimgetir($request),'adisyonlar'=>$adisyonlar,'pageindex'=>14, 'sayfa_baslik'=>'Seans Takibi','isletme'=>$isletme,'seanstakip'=>$adisyonlar, 'kalan_uyelik_suresi' => self::lisans_sure_kontrol($request),'urun_drop'=>self::urundropliste($request),'yetkiliolunanisletmeler'=>$isletmeler]);
    }
    /*Seans Takibi Veri Getirme Bloğu*/

   public function seans_getir(Request $request)
{
    $salon_id = self::mevcutsube($request);
    $adisyondurumu = 0;
    $musteriid = $request->musteriid;
    $paketHizmetId = $request->paketHizmetId ?? null;
    Log::info('paketHizmetId: ' . ($paketHizmetId ?? 'NULL'));
    // Sayfalama ekle (en önemli optimizasyon)
    $limit = $request->get('length', 10);
    $offset = $request->get('start', 0);
    $searchValue = $request->input('search.value');
    
    $commonConditions = [
        ['adisyonlar.salon_id', $salon_id],
    ];
    
    $customerFilter = $musteriid != '' ? ['adisyonlar.user_id', $musteriid] : null;

    // TOPLAM KAYIT SAYISI (pagination için)
    $totalRecords = DB::table('adisyon_paketler')
        ->leftJoin('adisyonlar', 'adisyon_paketler.adisyon_id', '=', 'adisyonlar.id')
        ->where($commonConditions)
        ->when($customerFilter, function($q) use ($customerFilter) {
            return $q->where([$customerFilter]);
        })
        ->count();
        
    $totalRecords += DB::table('adisyon_hizmetler')
        ->leftJoin('adisyonlar', 'adisyon_hizmetler.adisyon_id', '=', 'adisyonlar.id')
        ->where($commonConditions)
        ->when($customerFilter, function($q) use ($customerFilter) {
            return $q->where([$customerFilter]);
        })
        ->whereNotNull('adisyon_hizmetler.seans_sayisi')
        ->count();

    // ANA SORGU - sayfalama ile
    $paketlerQuery = DB::table('adisyon_paketler')
        ->leftJoin('adisyonlar', 'adisyon_paketler.adisyon_id', '=', 'adisyonlar.id')
        ->leftJoin('paketler', 'adisyon_paketler.paket_id', '=', 'paketler.id')
        ->leftJoin('users', 'adisyonlar.user_id', '=', 'users.id')
        ->select([
            'adisyon_paketler.id as id',
            'adisyonlar.created_at as olusturma_tarih',
            DB::raw('DATE_FORMAT(adisyon_paketler.baslangic_tarihi, "%d.%m.%Y") as baslangic_tarihi'),
            'users.name as musteri',
            DB::raw('paketler.paket_adi as paket_adi'),
            DB::raw('"paket" as tip'),
            DB::raw('"[]" as hizmet_detaylari'),
            DB::raw('"" as durum'),
            DB::raw('CONCAT("<button style=\"width:50px\" type=\"button\" class=\"btn btn-primary toggle-paket-detay\" data-value=\"",adisyon_paketler.id,"\"><i class=\"fa fa-chevron-down\"></i></button>") as islemler')
        ])
        ->where($commonConditions)
        ->when($customerFilter, function($q) use ($customerFilter) {
            return $q->where([$customerFilter]);
        })
        // TEK KAYIT İÇİN FİLTRE - ayrı bir where
        ->when($paketHizmetId, function($q) use ($paketHizmetId) {
            return $q->where('adisyon_paketler.id', $paketHizmetId);
        })
        // ARAMA FİLTRESİ - sadece searchValue varsa uygula
        ->when($searchValue, function($q) use ($searchValue) {
            return $q->where(function($subQ) use ($searchValue) {
                $subQ->where('users.name', 'like', '%'.$searchValue.'%')
                     ->orWhere('users.cep_telefon', 'like', '%'.$searchValue.'%')
                     ->orWhere('paketler.paket_adi', 'like', '%'.$searchValue.'%');
            });
        });

    $hizmetlerQuery = DB::table('adisyon_hizmetler')
        ->leftJoin('adisyonlar', 'adisyon_hizmetler.adisyon_id', '=', 'adisyonlar.id')
        ->leftJoin('hizmetler', 'adisyon_hizmetler.hizmet_id', '=', 'hizmetler.id')
        ->leftJoin('users', 'adisyonlar.user_id', '=', 'users.id')
        ->select([
            'adisyon_hizmetler.id as id',
            'adisyonlar.created_at as olusturma_tarih',
            DB::raw('DATE_FORMAT(adisyon_hizmetler.islem_tarihi, "%d.%m.%Y") as baslangic_tarihi'),
            'users.name as musteri',
            DB::raw('CONCAT(hizmetler.hizmet_adi, " (H)") as paket_adi'),
            DB::raw('"hizmet" as tip'),
            DB::raw('"[]" as hizmet_detaylari'),
            DB::raw('"" as durum'),
            DB::raw('CONCAT("<button style=\"width:50px\" type=\"button\" class=\"btn btn-primary toggle-paket-detay\" data-value=\"",adisyon_hizmetler.id,"\"><i class=\"fa fa-chevron-down\"></i></button>") as islemler')
        ])
        ->where($commonConditions)
        ->when($customerFilter, function($q) use ($customerFilter) {
            return $q->where([$customerFilter]);
        })
        // TEK KAYIT İÇİN FİLTRE - ayrı bir where
        ->when($paketHizmetId, function($q) use ($paketHizmetId) {
            return $q->where('adisyon_hizmetler.id', $paketHizmetId);
        })
        // ARAMA FİLTRESİ - sadece searchValue varsa uygula
        ->when($searchValue, function($q) use ($searchValue) {
            return $q->where(function($subQ) use ($searchValue) {
                $subQ->where('users.name', 'like', '%'.$searchValue.'%')
                     ->orWhere('users.cep_telefon', 'like', '%'.$searchValue.'%')
                     ->orWhere('hizmetler.hizmet_adi', 'like', '%'.$searchValue.'%');
            });
        })
        ->whereNotNull('adisyon_hizmetler.seans_sayisi');

    // Sayfalama ile sonuç
    $sonuc = $paketlerQuery->union($hizmetlerQuery)
        ->orderBy('id', 'desc')
        ->skip($offset)
        ->take($limit)
        ->get();

    // SADECE GÖSTERİLEN KAYITLAR için detayları getir
    foreach ($sonuc as $key => $item) {
        // Durum butonlarını oluştur
        $sonuc[$key]->durum = $this->createDurumButonlari($item->id, $item->tip);
        
        // Hizmet detaylarını getir (sadece bu id için)
        if ($item->tip == 'paket') {
            $sonuc[$key]->hizmet_detaylari = $this->getPaketDetaylari($item->id);
        } else {
            $sonuc[$key]->hizmet_detaylari = $this->getHizmetDetaylari($item->id);
        }
    }
    
    // DataTable formatında dön
    return response()->json([
        'draw' => intval($request->get('draw')),
        'recordsTotal' => $totalRecords,
        'recordsFiltered' => $totalRecords, // Arama yapılıyorsa burası değişmeli
        'data' => $sonuc
    ]);
}
private function createDurumButonlari($id, $tip)
{
    if ($tip == 'paket') {
        $toplam = DB::table('adisyon_paketler')
            ->where('id', $id)
            ->value('seans_sayisi') * DB::table('paket_hizmetler')
            ->whereIn('paket_id', function($q) use ($id) {
                $q->select('paket_id')->from('adisyon_paketler')->where('id', $id);
            })
            ->count();
            
        $kullanilan = DB::table('adisyon_paket_seanslar')
            ->where('adisyon_paket_id', $id)
            ->where('geldi', 1)
            ->count();
            
        $kullanilmayan = DB::table('adisyon_paket_seanslar')
            ->where('adisyon_paket_id', $id)
            ->where('geldi', 0)
            ->count();
    } else {
        $hizmet = DB::table('adisyon_hizmetler')->find($id);
        $toplam = $hizmet->seans_sayisi ?? 0;
        
        $kullanilan = DB::table('adisyon_paket_seanslar')
            ->where('adisyon_hizmet_id', $id)
            ->where('geldi', 1)
            ->count();
            
        $kullanilmayan = DB::table('adisyon_paket_seanslar')
            ->where('adisyon_hizmet_id', $id)
            ->where('geldi', 0)
            ->count();
    }
    
    $bekleyen = $toplam - $kullanilan - $kullanilmayan;
    
    return '<button name="paketteki_seanslar" data-value="'.$id.'" type="button" style="width:70px;font-size:10px" class="btn btn-primary">'.$toplam.' <i class="fa fa-plus"></i></button> &nbsp;' .
           '<button name="bekleyen_seanslar" data-value="'.$id.'" type="button" style="width:50px;font-size:10px" class="btn btn-warning">'.$bekleyen.' <i class="fa fa-calendar"></i></button> ' .
           '<button type="button" name="kullanilan_seanslar" data-value="'.$id.'" style="width:50px;font-size:10px" class="btn btn-success">'.$kullanilan.' <i class="fa fa-check"></i></button> ' .
           '<button type="button" name="kullanilmayan_seanslar" data-value="'.$id.'" style="width:50px;font-size:10px" class="btn btn-danger">'.$kullanilmayan.' <i class="fa fa-times"></i></button>';
}

private function getPaketDetaylari($paketId)
{
    $hizmetler = DB::table('paket_hizmetler')
        ->join('hizmetler', 'paket_hizmetler.hizmet_id', '=', 'hizmetler.id')
        ->where('paket_hizmetler.paket_id', function($q) use ($paketId) {
            $q->select('paket_id')->from('adisyon_paketler')->where('id', $paketId);
        })
        ->select('hizmetler.id as hizmetId', 'hizmetler.hizmet_adi')
        ->get();
    
    $musteriAdi = DB::table('adisyon_paketler')
        ->join('adisyonlar', 'adisyon_paketler.adisyon_id', '=', 'adisyonlar.id')
        ->join('users', 'adisyonlar.user_id', '=', 'users.id')
        ->where('adisyon_paketler.id', $paketId)
        ->value('users.name');
    
    $seansSayisi = DB::table('adisyon_paketler')
        ->where('id', $paketId)
        ->value('seans_sayisi');
    
    $detaylar = [];
    foreach ($hizmetler as $h) {
        $seanslar = DB::table('adisyon_paket_seanslar')
            ->where('adisyon_paket_id', $paketId)
            ->where('hizmet_id', $h->hizmetId)
            ->orderBy('seans_tarih')
            ->orderBy('seans_saat')
            ->get(['id', 'seans_tarih', 'seans_saat', 'geldi']);
        
        $detaylar[] = [
            'musteriAdi' => $musteriAdi,
            'id' => $paketId,
            'hizmetId' => $h->hizmetId,
            'hizmet_adi' => $h->hizmet_adi,
            'seansTuru' => 'PAKET',
            'toplam_seans' => $seansSayisi,
            'seans_detaylari' => $seanslar->toJson()
        ];
    }
    
    return json_encode($detaylar);
}

private function getHizmetDetaylari($hizmetId)
{
    $hizmet = DB::table('adisyon_hizmetler')
        ->join('hizmetler', 'adisyon_hizmetler.hizmet_id', '=', 'hizmetler.id')
        ->join('adisyonlar', 'adisyon_hizmetler.adisyon_id', '=', 'adisyonlar.id')
        ->join('users', 'adisyonlar.user_id', '=', 'users.id')
        ->where('adisyon_hizmetler.id', $hizmetId)
        ->select('users.name as musteriAdi', 'hizmetler.id as hizmetId', 'hizmetler.hizmet_adi', 'adisyon_hizmetler.seans_sayisi as toplam_seans')
        ->first();
    
    if (!$hizmet) return '[]';
    
    $seanslar = DB::table('adisyon_paket_seanslar')
        ->where('adisyon_hizmet_id', $hizmetId)
        ->orderBy('seans_tarih')
        
        ->get(['id', 'seans_tarih', 'seans_saat', 'geldi']);
    
    $detay = [
        'musteriAdi' => $hizmet->musteriAdi,
        'id' => $hizmetId,
        'hizmetId' => $hizmet->hizmetId,
        'hizmet_adi' => $hizmet->hizmet_adi,
        'seansTuru' => 'HIZMET',
        'toplam_seans' => $hizmet->toplam_seans,
        'seans_detaylari' => $seanslar->toJson()
    ];
    
    return json_encode([$detay]);
}





    public function satis_filtre(Request $request)
    {
        $adisyonlar = '';
        if($request->tarih1!=''&&$request->tarih2!='')
            $adisyonlar =self::adisyon_yukle($request,'','',date($request->tarih1.' 00:00:00'),date($request->tarih2.' 23:59:59'),'',$request->personel_id);
        else
            $adisyonlar =self::adisyon_yukle($request,'','',date($request->yil.'-'.$request->ay.'-01 00:00:00'),date($request->yil.'-'.$request->ay.'-d 23:59:59'),'',$request->personel_id);
        return array(
            'adisyonlar'=>$adisyonlar,
            'hizmet_satisi'=>number_format($adisyonlar->sum('hizmet_toplam_numeric'),2,',','.'),
            'hizmet_primi'=>number_format($adisyonlar->sum('hizmet_hakedis_numeric'),2,',','.'),
            'urun_satisi'=>number_format($adisyonlar->sum('urun_toplam_numeric'),2,',','.'),
            'urun_primi'=>number_format($adisyonlar->sum('urun_hakedis_numeric'),2,',','.'),
            'paket_satisi'=>number_format($adisyonlar->sum('paket_toplam_numeric'),2,',','.'),
            'paket_primi'=>number_format($adisyonlar->sum('paket_hakedis_numeric'),2,',','.'),
            'toplam_hakedis'=>number_format($adisyonlar->sum('hakedis_numeric'),2,',','.')
        );
    }
public function adisyon_yukle(Request $request, $adisyonturu, $adisyondurumu, $tarih1, $tarih2, $musteriid, $personelid)
{
    $isletmeId = self::mevcutsube($request);
    $length = $request->input('length');
    $start = $request->input('start', 0);
    $searchValue = $request->input('search.value');
    
    if ($length == 0) {
        $length = 10;
    }
    $currentPage = ($start / $length) + 1;
    
    // Request'ten filtre parametrelerini al
    $adisyonturu = $request->input('tur', 0); // 0:tümü, 1:hizmet, 2:paket, 3:urun
    $adisyondurumu = $request->input('adisyondurumu', ''); // 'acik', 'kapali', ''
    $tariharaligi = $request->input('tariharaligi', '');
    $personel_id = $request->input('personel_id', '');
    $musteri_id = $request->input('musteri_id', '');


     Log::info("DEBUG: Müşteri ID değeri: '$musteri_id'");
    Log::info("DEBUG: Müşteri ID tipi: " . gettype($musteri_id));
    Log::info("DEBUG: Müşteri ID == '': " . ($musteri_id == '' ? 'EVET' : 'HAYIR'));
    Log::info("DEBUG: Müşteri ID === '': " . ($musteri_id === '' ? 'EVET' : 'HAYIR'));
    Log::info("DEBUG: Müşteri ID empty(): " . (empty($musteri_id) ? 'EVET' : 'HAYIR'));
    
    
    
    // Temel sorgu
    $adisyonlar = Adisyonlar::with([
        'musteri:id,name',
        'hizmetler' => function ($q) use ($personel_id) {
            $q->select('id', 'adisyon_id', 'hizmet_id', "fiyat", "personel_id")
              ->with(['hizmet:id,hizmet_adi'])
              ->with('tahsilatlar:id,adisyon_hizmet_id,tutar');
            if ($personel_id) {
                $q->where('personel_id', $personel_id);
            }
        },
        'urunler' => function ($q) use ($personel_id) {
            $q->select('id', 'adisyon_id', 'urun_id', "fiyat", "personel_id")
              ->with(['urun:id,urun_adi'])
              ->with('tahsilatlar:id,adisyon_urun_id,tutar');
            if ($personel_id) {
                $q->where('personel_id', $personel_id);
            }
        },
        'paketler' => function ($q) use ($personel_id) {
            $q->select('id', 'adisyon_id', 'paket_id', "fiyat", "personel_id")
              ->with(['paket:id,paket_adi'])
              ->with('tahsilatlar:id,adisyon_paket_id,tutar');
            if ($personel_id) {
                $q->where('personel_id', $personel_id);
            }
        },
    ])
    ->where(function($q) use($searchValue) {
        if ($searchValue) {
            $q->whereHas('musteri', function($q2) use($searchValue) {
                $q2->where('name','like','%'.$searchValue.'%')
                   ->orWhere('cep_telefon','like','%'.$searchValue.'%');
            });
            $q->orWhereHas('hizmetler', function($q2) use($searchValue) {
                $q2->whereHas('hizmet', function($q3) use($searchValue) {
                    $q3->where('hizmet_adi','like','%'.$searchValue.'%');
                });
            });
            $q->orWhereHas('urunler', function($q2) use($searchValue) {
                $q2->whereHas('urun', function($q3) use($searchValue) {
                    $q3->where('urun_adi','like','%'.$searchValue.'%');
                });
            });
            $q->orWhereHas('paketler', function($q2) use($searchValue) {
                $q2->whereHas('paket', function($q3) use($searchValue) {
                    $q3->where('paket_adi','like','%'.$searchValue.'%');
                });
            });
        }
    })
    ->where('salon_id', $isletmeId)
    ->whereBetween('adisyonlar.tarih', [$tarih1, $tarih2])
    ->where(function($q) use($musteri_id) {
        if ($musteri_id != '') {
            $q->where('adisyonlar.user_id', $musteri_id);
        }
    });
    
    // Adisyon türüne göre filtreleme
    if ($adisyonturu == '1') {
        $adisyonlar->whereHas('hizmetler');
    } elseif ($adisyonturu == '3') {
        $adisyonlar->whereHas('urunler');
    } elseif ($adisyonturu == '2') {
        $adisyonlar->whereHas('paketler');
    }
    
    $adisyonlar->orderBy('tarih', 'desc');
    
    // Tüm adisyonları al
    $tumAdisyonlar = $adisyonlar->get();
    
    // Adisyon durumuna göre filtreleme
    $filtrelenmisAdisyonlar = collect();
    $acikAdisyonSayisi = 0;
    $kapaliAdisyonSayisi = 0;
    $tumAdisyonAcikSayisi = 0;
    $tumAdisyonKapaliSayisi = 0;
    
    foreach ($tumAdisyonlar as $adisyon) {
        // Personel filtreli toplam hesapla
        $toplamTutar = 0;
        $odenenTutar = 0;
        
        // Hizmetler
        $hizmetler = $adisyon->hizmetler;
        if ($personel_id) {
            $hizmetler = $hizmetler->where('personel_id', $personel_id);
        }
        $toplamTutar += $hizmetler->sum('fiyat');
        $odenenTutar += $hizmetler->sum(function($h) {
            return $h->tahsilatlar->sum('tutar');
        });
        
        // Ürünler
        $urunler = $adisyon->urunler;
        if ($personel_id) {
            $urunler = $urunler->where('personel_id', $personel_id);
        }
        $toplamTutar += $urunler->sum('fiyat');
        $odenenTutar += $urunler->sum(function($u) {
            return $u->tahsilatlar->sum('tutar');
        });
        
        // Paketler
        $paketler = $adisyon->paketler;
        if ($personel_id) {
            $paketler = $paketler->where('personel_id', $personel_id);
        }
        $toplamTutar += $paketler->sum('fiyat');
        $odenenTutar += $paketler->sum(function($p) {
            return $p->tahsilatlar->sum('tutar');
        });
        
        // Eğer tür filtreliysek ve bu türde satış yoksa atla
        if ($adisyonturu == '1' && $hizmetler->isEmpty()) continue;
        if ($adisyonturu == '3' && $urunler->isEmpty()) continue;
        if ($adisyonturu == '2') {
            if($paketler->isEmpty())
            {
                $seansVarMi = $hizmetler->contains(function($h) {
                    return $h->seanslar->isNotEmpty();
                });

                if (!$seansVarMi) {
                    continue;
                } 
            }
            

        }
        
        // Personel filtreliysek ve hiç satış yoksa atla
        if ($personel_id && $hizmetler->isEmpty() && $urunler->isEmpty() && $paketler->isEmpty()) continue;
        
        $kalanTutar = $toplamTutar - $odenenTutar;
        $durum = $kalanTutar > 0 ? 'acik' : 'kapali';
        
        // TÜM adisyonlar için sayıları hesapla (filtreden bağımsız)
        $tumDurum = $kalanTutar > 0 ? 'acik' : 'kapali';
        if ($tumDurum == 'acik') {
            $tumAdisyonAcikSayisi++;
        } else {
            $tumAdisyonKapaliSayisi++;
        }
        
        // Adisyon durumu filtresine göre ekle
        if ($adisyondurumu == '') {
            // Tüm adisyonlar - durum sayılarını burada hesapla
            if ($durum == 'acik') {
                $acikAdisyonSayisi++;
            } else {
                $kapaliAdisyonSayisi++;
            }
            
            $adisyon->toplam_tutar = $toplamTutar;
            $adisyon->odenen_tutar = $odenenTutar;
            $adisyon->kalan_tutar = $kalanTutar;
            $adisyon->durum = $durum;
            $filtrelenmisAdisyonlar->push($adisyon);
        } elseif ($adisyondurumu == 'acik' && $durum == 'acik') {
            // Sadece açık adisyonlar
            $acikAdisyonSayisi++;
            $adisyon->toplam_tutar = $toplamTutar;
            $adisyon->odenen_tutar = $odenenTutar;
            $adisyon->kalan_tutar = $kalanTutar;
            $adisyon->durum = $durum;
            $filtrelenmisAdisyonlar->push($adisyon);
        } elseif ($adisyondurumu == 'kapali' && $durum == 'kapali') {
            // Sadece kapalı adisyonlar
            $kapaliAdisyonSayisi++;
            $adisyon->toplam_tutar = $toplamTutar;
            $adisyon->odenen_tutar = $odenenTutar;
            $adisyon->kalan_tutar = $kalanTutar;
            $adisyon->durum = $durum;
            $filtrelenmisAdisyonlar->push($adisyon);
        }
    }
    
    // Personel filtreli sayıları hesapla
    $islemSayisi = 0;
    $urunSayisi = 0;
    $paketSayisi = 0;
    
    foreach ($filtrelenmisAdisyonlar as $adisyon) {
        $islemSayisi += $adisyon->hizmetler->count();
        $urunSayisi += $adisyon->urunler->count();
        $paketSayisi += $adisyon->paketler->count();
    }
    
    // Toplam tutarları hesapla
    $odenenToplamTutar = 0;
    $kalanToplamTutar = 0;
    $toplamSatisTutar = 0;
    
    foreach ($filtrelenmisAdisyonlar as $adisyon) {
        $odenenToplamTutar += $adisyon->odenen_tutar;
        $kalanToplamTutar += $adisyon->kalan_tutar;
        $toplamSatisTutar += $adisyon->toplam_tutar;
    }
    
    // Sayfalama için slice yap
    $startIndex = $start;
    $endIndex = min($start + $length, $filtrelenmisAdisyonlar->count());
    $sayfalanmisAdisyonlar = $filtrelenmisAdisyonlar->slice($startIndex, $length)->values();
    
    // Toplam hesaplamalar
    $hizmetHakedisToplam = 0;
    $urunHakedisToplam = 0;
    $paketHakedisToplam = 0;
    $hizmetSatisToplam = 0;
    $paketSatisToplam = 0;
    $urunSatisToplam = 0;
    
    $formatted = $sayfalanmisAdisyonlar->map(function ($adisyon) use ($isletmeId, $personel_id, &$hizmetHakedisToplam, &$urunHakedisToplam, &$paketHakedisToplam, &$hizmetSatisToplam, &$urunSatisToplam, &$paketSatisToplam) {
        $satilanlar = [];
        $satilanlarStr = "";
        
        // Hizmetler
        $hizmetler = $adisyon->hizmetler;
        foreach ($hizmetler as $hizmet) {
            $hizmetHakedis = 0;
            if ($hizmet->personel_id !== null) {
                if (isset($hizmet->personel->hizmet_prim_yuzde)) {
                    $hizmetHakedis = $hizmet->tahsilatlar->sum('tutar') * ($hizmet->personel->hizmet_prim_yuzde / 100);
                }
            }
            
            $satilanlarStr .= $hizmet->hizmet_id ? $hizmet->hizmet->hizmet_adi." (H) " : "";
            $satilanlar[] = [
                'tip' => 'hizmet',
                'ad' => $hizmet->hizmet_id ? $hizmet->hizmet->hizmet_adi : "",
                'tutar' => $hizmet->fiyat,
                'hizmetTutar' => $hizmet->fiyat,
                'urunTutar' => 0,
                'paketTutar' => 0,
                'hakedisTutar' => $hizmetHakedis,
                'hizmetHakedisTutar' => $hizmetHakedis,
                'urunHakedisTutar' => 0,
                'paketHakedisTutar' => 0,
            ];
        }
        
        // Ürünler
        $urunler = $adisyon->urunler;
        foreach ($urunler as $urun) {
            $urunHakedis = 0;
            if ($urun->personel_id !== null) {
                if (isset($urun->personel->urun_prim_yuzde)) {
                    $urunHakedis = $urun->tahsilatlar->sum('tutar') * ($urun->personel->urun_prim_yuzde / 100);
                }
            }
            
            $satilanlarStr .= $urun->urun_id ? $urun->urun->urun_adi." (Ü) " : "";
            $satilanlar[] = [
                'tip' => 'urun',
                'ad' => $urun->urun_id ? $urun->urun->urun_adi : "",
                'tutar' => $urun->fiyat,
                'hizmetTutar' => 0,
                'urunTutar' => $urun->fiyat,
                'paketTutar' => 0,
                'hakedisTutar' => $urunHakedis,
                'hizmetHakedisTutar' => 0,
                'urunHakedisTutar' => $urunHakedis,
                'paketHakedisTutar' => 0,
            ];
        }
        
        // Paketler
        $paketler = $adisyon->paketler;
        foreach ($paketler as $paket) {
            $paketHakedis = 0;
            if ($paket->personel_id !== null) {
                if (isset($paket->personel->paket_prim_yuzde)) {
                    $paketHakedis = $paket->tahsilatlar->sum('tutar') * ($paket->personel->paket_prim_yuzde / 100);
                }
            }
            
            $satilanlarStr .= $paket->paket_id ? $paket->paket->paket_adi." (P) " : "";
            $satilanlar[] = [
                'tip' => 'paket',
                'ad' => $paket->paket_id ? $paket->paket->paket_adi : "",
                'tutar' => $paket->fiyat,
                'hizmetTutar' => 0,
                'urunTutar' => 0,
                'paketTutar' => $paket->fiyat,
                'hakedisTutar' => $paketHakedis,
                'hizmetHakedisTutar' => 0,
                'urunHakedisTutar' => 0,
                'paketHakedisTutar' => $paketHakedis,
            ];
        }
        
        $toplamTutar = collect($satilanlar)->sum('tutar');
        $hizmetToplam = collect($satilanlar)->sum('hizmetTutar');
        $urunToplam = collect($satilanlar)->sum('urunTutar');
        $paketToplam = collect($satilanlar)->sum('paketTutar');
        
        $hizmetSatisToplam += $hizmetToplam;
        $urunSatisToplam += $urunToplam;
        $paketSatisToplam += $paketToplam;
        
        $odenen = $adisyon->odenen_tutar;
        $kalanVar = $adisyon->kalan_tutar;
        
        $hakedisTutar = collect($satilanlar)->sum('hakedisTutar');
        $hizmetHakedisTutar = collect($satilanlar)->sum('hizmetHakedisTutar');
        $urunHakedisTutar = collect($satilanlar)->sum('urunHakedisTutar');
        $paketHakedisTutar = collect($satilanlar)->sum('paketHakedisTutar');
        
        $hizmetHakedisToplam += $hizmetHakedisTutar;
        $urunHakedisToplam += $urunHakedisTutar;
        $paketHakedisToplam += $paketHakedisTutar;
        
        $ilkAlacak = Alacaklar::where('user_id', $adisyon->user_id)
            ->orderBy('planlanan_odeme_tarihi', 'asc')
            ->first();
        
        // Adisyon durumuna göre renk belirle
        $durumRenk = $kalanVar == 0 ? 'success' : 'warning';
        $durumText = $kalanVar == 0 ? 'KAPALI' : 'AÇIK';
        
        $islemler = "";
        
        if ($kalanVar == 0) {
            $islemler = '<a style="line-height:5px;padding:5px" title="Ödeme Bilgileri" href="#" name="adisyon_odeme_detaylari" type="button" data-value="'.$adisyon->id.'"  class="btn btn-primary"><i class="dw dw-eye"></i></a>';
           
        } else { 
        $islemler = '<a style="line-height:5px;padding:5px" title="Tahsil Et" href="/isletmeyonetim/tahsilat/'.$adisyon->user_id.'/'.$adisyon->id.'?sube='.$isletmeId.'" type="button"  class="btn btn-success"><i class="fa fa-money"></i></a>';
        }
        
        $islemler .= '&nbsp;<button style="line-height:5px;padding:5px" name="satisDuzenle" data-index-number="'.$adisyon->user_id.'" data-value="'.$adisyon->id.'" title="Düzenle" href="#" type="button"  class="btn btn-success"><i class="fa fa-edit"></i></button>';
        $islemler .= '&nbsp;<button style="line-height:5px;padding:5px"  class="btn btn-danger" href="#" title="Adisyonu Sil"  name="adisyon_sil" data-value="'.$adisyon->id.'"><i class="fa fa-times"></i></button>';
        
        return [
            'acilis_tarihi' => date('d.m.Y', strtotime($adisyon->tarih)),
            'musteri' => optional($adisyon->musteri)->name ?? '-',
            'planlanan_alacak_tarihi' => $ilkAlacak && $ilkAlacak->planlanan_odeme_tarihi !== null ? date('d.m.Y', strtotime($ilkAlacak->planlanan_odeme_tarihi)) : "",
            'satis_turu' => '',
            'icerik' => $satilanlarStr,
            'durum' => '<span class="badge badge-'.$durumRenk.'">'.$durumText.'</span>',
            'toplam' => '<button class="btn btn-primary btn-block" style="line-height:5px">'.number_format($toplamTutar, 2, ',', '.').'</button>',
            'odenen' => '<button class="btn btn-success btn-block" style="line-height:5px">'.number_format($odenen, 2, ',', '.').'</button>',
            'kalan_tutar' => '<button class="btn btn-'.($kalanVar > 0 ? 'danger' : 'secondary').' btn-block" style="line-height:5px">'.number_format($kalanVar, 2, ',', '.').'</button>',
            'hakedisTutar' => $hakedisTutar,
            'hizmetHakedisTutar' => $hizmetHakedisTutar,
            'urunHakedisTutar' => $urunHakedisTutar,
            'paketHakedisTutar' => $paketHakedisTutar,
            'hizmetToplam' => $hizmetToplam,
            'urunToplam' => $urunToplam,
            'paketToplam' => $paketToplam,
            'islemler' => $islemler,
        ];
    });
    
    // Null değerleri filtrele
    $formatted = $formatted->filter(function($item) {
        return $item !== null;
    });
    
    return response()->json([
        'data' => $formatted->values(),
        'draw' => $request->input('draw'),
        'recordsTotal' => $filtrelenmisAdisyonlar->count(),
        'recordsFiltered' => $filtrelenmisAdisyonlar->count(),
        'hizmetSatislariToplami' => number_format($hizmetSatisToplam, 2, ',', '.'),
        'hizmetHakedisleriToplami' => number_format($hizmetHakedisToplam, 2, ',', '.'),
        'urunSatislariToplami' => number_format($urunSatisToplam, 2, ',', '.'),
        'urunHakedisleriToplami' => number_format($urunHakedisToplam, 2, ',', '.'),
        'paketSatislariToplami' => number_format($paketSatisToplam, 2, ',', '.'),
        'paketHakedisleriToplami' => number_format($paketHakedisToplam, 2, ',', '.'),
        'primHakedisleriToplami' => number_format($hizmetHakedisToplam + $urunHakedisToplam + $paketHakedisToplam, 2, ',', '.'),
        'odenen' => number_format($odenenToplamTutar, 2, ',', '.'),
        'kalan' => number_format($kalanToplamTutar, 2, ',', '.'),
        'toplamSatis' => number_format($toplamSatisTutar, 2, ',', '.'),
        'islemsayisi' => $islemSayisi,
        'urunsayisi' => $urunSayisi,
        'paketsayisi' => $paketSayisi,
        'acikAdisyonSayisi' => $acikAdisyonSayisi,
        'kapaliAdisyonSayisi' => $kapaliAdisyonSayisi,
        'tumAdisyonAcikSayisi' => $tumAdisyonAcikSayisi, // Yeni: Tüm açık adisyon sayısı
        'tumAdisyonKapaliSayisi' => $tumAdisyonKapaliSayisi, // Yeni: Tüm kapalı adisyon sayısı
        'toplamAdisyonSayisi' => $tumAdisyonAcikSayisi + $tumAdisyonKapaliSayisi // Yeni: Toplam adisyon sayısı
    ]);
