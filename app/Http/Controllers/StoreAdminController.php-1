                        (SELECT senet_vadeleri.vade_tarih FROM senet_vadeleri WHERE senet_vadeleri.odendi=false AND senet_vadeleri.senet_id = senetler.id
                                order by senet_vadeleri.id asc  LIMIT 1),"%d.%m.%Y"
                    ),"</span>") END as yaklasan_vade'),*/
