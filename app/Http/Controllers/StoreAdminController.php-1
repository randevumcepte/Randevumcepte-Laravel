    public function salonAppyRandevuSatisAktarma(Request $request)
    {
       
        $fullPath = storage_path("app/" . $request->dosya);

        try {
            $import = new SatisImportSA($request->salonid);
            $result = Excel::import($import, $request->dosya);
            dd("İşlem başarılı", $result);
        } catch (\Exception $e) {
            dd("Import sırasında hata oluştu", $e->getMessage(), $e->getTraceAsString());
        }
    }
