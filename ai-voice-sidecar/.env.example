# Groq API (https://console.groq.com → API Keys)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM model (Groq Llama 3.3 70B Versatile, free tier)
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# STT model (Groq Whisper, free tier)
GROQ_STT_MODEL=whisper-large-v3

# TTS — Microsoft Edge TTS Türkçe sesleri
# Kadın: tr-TR-EmelNeural   |   Erkek: tr-TR-AhmetNeural
TTS_VOICE=tr-TR-EmelNeural
TTS_RATE=+0%
TTS_PITCH=+0Hz

# Laravel API (sidecar randevu CRUD için)
# LARAVEL_API_TOKEN BOS BIRAKILIRSA: sidecar mock data kullanir (Laravel'siz test).
# DOLU OLURSA: gercek Laravel API'sine baglanir. Token Laravel .env'sindeki
# AI_SIDECAR_TOKEN ile AYNI olmali. (ornek: openssl rand -hex 32 ile uret)
LARAVEL_API_BASE=https://apptest.randevumcepte.com.tr/api
LARAVEL_API_TOKEN=

# Çıktı klasörü (test ses dosyaları)
OUTPUT_DIR=./output

# Salon kimliği (test için, prod'da arayan numaradan tespit edilecek)
TEST_SALON_ID=15

# ─────────── Asterisk ARI bağlantısı (Faz 2) ───────────
# Asterisk sunucusunun adresi. Aynı sunucudaysa: localhost
# Farklı sunucudaysa: Asterisk'in IP'si (firewall'da port 8088 sidecar IP'sine acik olmali)
ASTERISK_HOST=localhost
ASTERISK_ARI_PORT=8088
ASTERISK_ARI_USER=randevu_ai
ASTERISK_ARI_PASS=ari_parolasi_burada
# Stasis app adi — extensions.conf'taki Stasis(<bu_isim>,...) ile AYNI olmali
ASTERISK_STASIS_APP=randevu_ai

# Sidecar'in External Media (RTP audio) icin dinleyecegi UDP port araligi
# Aynı sunucudaysa default yeter; farkliysa firewall'da bu portlari ac
RTP_PORT_BASE=10000
RTP_PORT_COUNT=1000

# DID (aranan numara) → salon_id eslemesi (Faz 2'de Laravel'den de cekilebilir)
# Format: "did1:salonid1,did2:salonid2"
# Bos birakilirsa TEST_SALON_ID kullanilir
DID_SALON_MAP=

# ─────────── Orkestrator (src/server.js) ayarlari ───────────
# Asterisk ses dosyalari icin path'ler. Default Debian/FreePBX yollari.
ASTERISK_SOUNDS_DIR=/var/lib/asterisk/sounds
ASTERISK_RECORDINGS_DIR=/var/spool/asterisk/recording
# TTS ciktilari sounds altinda hangi alt klasore yazilsin (Asterisk play "sound:<bu>/dosya")
ASTERISK_TTS_SUBDIR=ai_tts

# Tek bir kayit penceresi en fazla kac saniye, kac saniye sessizlikten sonra durur
MAX_RECORD_SECONDS=15
MAX_SILENCE_SECONDS=2
# Bir cagrida en fazla kac LLM turu (sonsuz dongu emniyeti)
MAX_TURNS=12

# Sidecar "operatore aktar" derse cagriyi hangi dialplan'e dusursun
# (FreePBX'te genelde mevcut IVR'in giris context'i — ASTERISK-KURULUM.md 3.2 bolumune bak)
TRANSFER_CONTEXT=from-trunk-custom
TRANSFER_EXTEN=s
TRANSFER_PRIORITY=1

# Sistem promptunda kullanilacak salon adi (gecici — sonra Laravel'den cekilecek)
SALON_ADI=Salon
