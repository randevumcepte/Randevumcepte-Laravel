# Groq API (https://console.groq.com → API Keys)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM model (Groq Llama 3.3 70B Versatile, free tier)
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# STT model (Groq Whisper, free tier)
GROQ_STT_MODEL=whisper-large-v3

# TTS — Microsoft Edge TTS Türkçe sesleri
# Kadın: tr-TR-EmelNeural   |   Erkek: tr-TR-AhmetNeural
TTS_VOICE=tr-TR-EmelNeural
TTS_RATE=+0%
TTS_PITCH=+0Hz

# Laravel API (sidecar randevu CRUD için)
# LARAVEL_API_TOKEN BOS BIRAKILIRSA: sidecar mock data kullanir (Laravel'siz test).
# DOLU OLURSA: gercek Laravel API'sine baglanir. Token Laravel .env'sindeki
# AI_SIDECAR_TOKEN ile AYNI olmali. (ornek: openssl rand -hex 32 ile uret)
LARAVEL_API_BASE=https://apptest.randevumcepte.com.tr/api
LARAVEL_API_TOKEN=

# Çıktı klasörü (test ses dosyaları)
OUTPUT_DIR=./output

# Salon kimliği (test için, prod'da arayan numaradan tespit edilecek)
TEST_SALON_ID=15
